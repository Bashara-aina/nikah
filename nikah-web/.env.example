# ── nikah-web ──────────────────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in the real values. `.env.local`
# is gitignored; never commit it. Production secrets live in the Vercel
# dashboard (Settings → Environment Variables).
#
# See docs/ for the full env contract:
#   docs/spec/*  — engineering spec
#   NIKAH-MASTER-TECHSTACK.md §3 — public-facing env contract
#   NIKAH-MASTER-TECHSTACK.md §7 — MiniMax proxy contract

# ── Site ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_MAPS_URL=

# ── Couple / event content (also in lib/config.ts) ────────────────────────
NEXT_PUBLIC_COUPLE_NAMES=
NEXT_PUBLIC_WEDDING_DATE=
NEXT_PUBLIC_VENUE_NAME=

# ── RSVP / Wishes (Google Apps Script webhook) ────────────────────────────
# Apps Script Web App URL (the /exec endpoint).
APPS_SCRIPT_URL=
# Shared secret that the Apps Script checks before writing to the sheet.
APPS_SCRIPT_TOKEN=

# ── MiniMax image / video generation (server-only) ───────────────────────
# The MiniMax API key. Read by /api/minimax/* routes server-side.
# Optional in the env: if absent, the client must send the same key as
# `Authorization: Bearer <key>` on every request. If set, the route uses
# this value as the upstream credential and the client bearer is ignored.
MINIMAX_API_KEY=
# MiniMax group id, sent alongside requests to attribute usage.
MINIMAX_GROUP_ID=
# Optional overrides for the MiniMax endpoints.
# Defaults: image=https://api.minimaxi.chat/v1/image_generation
#           video=https://api.minimaxi.chat/v1/video_generation
#           video-query=https://api.minimaxi.chat/v1/query/video_generation
# MINIMAX_ENDPOINT=
# MINIMAX_VIDEO_ENDPOINT=
# MINIMAX_VIDEO_QUERY_ENDPOINT=
